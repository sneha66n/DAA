class LibraryItem {
public:
    virtual float calculateFine(int days) = 0;
    virtual void display() = 0;
    virtual ~LibraryItem() {}
};

// BOOK CLASS
class Book : public LibraryItem {
private:
    string title;

public:
    Book(string t) {
        title = t;
    }

    float calculateFine(int days) {
        return days * 0.5;   // 0.5$ per day
    }

    void display() {
        cout << "Book: " << title << endl;
    }
};

// MEDIA CLASS
class Media : public LibraryItem {
private:
    string title;

public:
    Media(string t) {
        title = t;
    }

    float calculateFine(int days) {
        return days * 2;   // 2$ per day
    }

    void display() {
        cout << "Media: " << title << endl;
    }
};

// BOOKER CLASS (Customer)
class Booker {
private:
    int id;
    string name;

public:
    Booker(int i, string n) {
        id = i;
        name = n;
    }

    void display() {
        cout << "Customer ID: " << id << ", Name: " << name << endl;
    }
};

// TRANSACTION CLASS (connects item + customer)
class Transaction {
private:
    LibraryItem* item;
    Booker* user;
    int days;

public:
    Transaction(LibraryItem* i, Booker* u, int d) {
        item = i;
        user = u;
        days = d;
    }

    float getFine() {
        return item->calculateFine(days);
    }

    void display() {
        user->display();
        item->display();
        cout << "Days late: " << days << endl;
        cout << "Fine: " << getFine() << endl;
    }
};

// LIBRARY MANAGER CLASS
class LibraryManager {
private:
    vector<Transaction*> tlist;

public:
    void addTransaction(Transaction* t) {
        tlist.push_back(t);
    }

    void generateReport() {
        float total = 0;
        cout << "\n--- Library Report ---\n";

        for (int i = 0; i < tlist.size(); i++) {
            tlist[i]->display();
            total += tlist[i]->getFine();
            cout << "------------------\n";
        }

        cout << "Total Fine: " << total << endl;
    }
};

int main() {
    LibraryManager manager;

    int n;
    cout << "Enter number of transactions: ";
    cin >> n;

    for (int i = 0; i < n; i++) {
        int id, days, type;
        string name, title;

        cout << "\nEnter customer id and name: ";
        cin >> id >> name;

        Booker* b = new Booker(id, name);

        cout << "Enter item type (1=Book, 2=Media): ";
        cin >> type;

        cout << "Enter title: ";
        cin >> title;

        cout << "Enter late days: ";
        cin >> days;

        LibraryItem* item;

        if (type == 1)
            item = new Book(title);
        else
            item = new Media(title);

        try {
            if (days < 0)
                throw 1;

            Transaction* t = new Transaction(item, b, days);
            manager.addTransaction(t);
        }
        catch (...) {
            cout << "Invalid days! Try again.\n";
            i--;
        }
    }

    manager.generateReport();

    // SIMPLE FILE HANDLING
