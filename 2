    books() {
        id = 0;
        title = "";
        price = 0;
    }

    books(int i, string t, float p) {
        id = i;
        title = t;
        price = p;
    }

    float getprice() {
        return price;
    }

    void accept() {
        cout << "Enter ID, Title and Price: ";
        cin >> id >> title >> price;
    }

    void display() {
        cout << "ID: " << id << " Title: " << title << " Price: " << price << endl;
    }

    void write(ofstream &ofile) {
        ofile << id << " " << title << " " << price << endl;
    }
};

int main() {
    vector<books> b;
    int id;
    string title;
    float price;

    ifstream ifile("log.txt");
    if (ifile) {
        while (ifile >> id >> title >> price) {
            b.push_back(books(id, title, price));
        }
        ifile.close();
    }

    int n;
    cout << "Enter number of books to add: ";
    cin >> n;

    ofstream ofile("log.txt", ios::app);

    for (int i = 0; i < n; i++) {
        books temp;
        temp.accept();
        b.push_back(temp);
        temp.write(ofile);
    }

    ofile.close();

    cout << "\nBooks:\n";
    for (auto it = b.begin(); it != b.end(); it++) {
        it->display();
    }

    float total = 0;
    for (auto it = b.begin(); it != b.end(); it++) {
        total += it->getprice();
    }

    cout << "\nTotal price: " << total << endl;

    char choice;
    cout << "\nDo you want to add more books? (y/n): ";
    cin >> choice;

    while (choice == 'y' || choice == 'Y') {
