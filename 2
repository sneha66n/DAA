        ofile.close();

        cout << "Add more? (y/n): ";
        cin >> choice;
    }

    total = 0;
    for (auto it = b.begin(); it != b.end(); it++) {
        total += it->getprice();
    }

    cout << "\nUpdated total price: " << total << endl;

    return 0;
}
