#include <iostream>
#include <vector>
#include <fstream>
using namespace std;

class Employee {
protected:
    int id;
    string name;
    float basic;

public:
    Employee() {
        id = 0;
        name = "";
        basic = 0;
    }

    Employee(int i, string n, float b) {
        id = i;
        name = n;
        basic = b;
    }

    virtual float calculateSalary() {
        return basic;
    }

    virtual void display() {
        cout << "ID: " << id << " Name: " << name << " Salary: " << calculateSalary() << endl;
    }

    virtual void write(ofstream &ofile) {
        ofile << id << " " << name << " " << basic << endl;
    }

    virtual ~Employee() {}
};

class Manager : public Employee {
    float allowance;

public:
    Manager(int i, string n, float b, float a) : Employee(i, n, b) {
        allowance = a;
    }

    float calculateSalary() {
        return basic + allowance;
    }

    void display() {
        cout << "ID: " << id << " Name: " << name
             << " Total Salary: " << calculateSalary() << endl;
    }

    void write(ofstream &ofile) {
        ofile << id << " " << name << " " << basic << " " << allowance << endl;
    }
};

int main() {
    vector<Employee*> emp;
    int n;

    cout << "Enter number of employees: ";
    cin >> n;

    for(int i = 0; i < n; i++) {
        int id;
        string name;
        float basic, allowance;

        cout << "Enter ID, Name, Basic Salary and Allowance: ";
        cin >> id >> name >> basic >> allowance;

        try {
            if(basic < 0) throw "Invalid salary";

            emp.push_back(new Manager(id, name, basic, allowance));
        }
        catch(const char* msg) {
            cout << msg << endl;
        }
    }

    cout << "\nEmployee Details:\n";
    for(auto it = emp.begin(); it != emp.end(); it++) {
        (*it)->display();
    }

    float total = 0;
    for(auto it = emp.begin(); it != emp.end(); it++) {
        total += (*it)->calculateSalary();
    }

    cout << "\nTotal Salary: " << total << endl;

    ofstream ofile("salary.txt");
    for(auto it = emp.begin(); it != emp.end(); it++) {
        (*it)->write(ofile);
    }
    ofile.close();

    for(auto it = emp.begin(); it != emp.end(); it++) {
        delete *it;
    }

    return 0;
}
