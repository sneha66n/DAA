class Account {
protected:
    int accNo;
    string name;

public:
    Account(int a, string n) {
        accNo = a;
        name = n;
    }

    virtual void calculate() = 0;   // for operations
    virtual void display() = 0;

    virtual ~Account() {
        cout << "Account Destructor\n";
    }
};

// DERIVED CLASS
class ATM : public Account {
private:
    float balance;

public:
    // Constructor
    ATM(int a, string n, float b) : Account(a, n) {
        balance = b;
    }

    // Overloading (compile-time polymorphism)
    void deposit(float amt) {
        balance += amt;
    }

    void deposit(float amt, int bonus) {
        balance += amt + bonus;
    }

    // Withdraw
    void withdraw(float amt) {
        if (amt > balance)
            cout << "Insufficient balance\n";
        else
            balance -= amt;
    }

    // Runtime polymorphism
    void calculate() {
        cout << "Current Balance: " << balance << endl;
    }

    void display() {
        cout << "Account No: " << accNo << ", Name: " << name << endl;
    }

    ~ATM() {
        cout << "ATM Destructor\n";
    }
};

int main() {
    vector<Account*> v;

    int n;
    cout << "Enter number of accounts: ";
    cin >> n;

    // INPUT
    for (int i = 0; i < n; i++) {
        int accNo;
        string name;
        float balance;

        cout << "\nEnter account no and name: ";
        cin >> accNo >> name;

        cout << "Enter initial balance: ";
        cin >> balance;

        try {
            if (balance < 0)
                throw 1;

            v.push_back(new ATM(accNo, name, balance));
        }
        catch (...) {
            cout << "Invalid balance! Try again.\n";
            i--;
        }
    }

    // OPERATIONS
    int choice;
    do {
        cout << "\n1. Display\n2. Deposit\n3. Withdraw\n4. Exit\nEnter choice: ";
        cin >> choice;

        for (int i = 0; i < v.size(); i++) {
            ATM* a = (ATM*)v[i];   // simple cast

            if (choice == 1) {
                a->display();
                a->calculate();
            }
            else if (choice == 2) {
                float amt;
                cout << "Enter deposit amount: ";
                cin >> amt;
                a->deposit(amt);
            }
            else if (choice == 3) {
                float amt;
                cout << "Enter withdraw amount: ";
                cin >> amt;
                a->withdraw(amt);
            }
        }

    } while (choice != 4);

    // SIMPLE FILE HANDLING
    ofstream fout("data.txt");
    fout << "ATM operations completed\n";
    fout.close();

    ifstream fin("data.txt");
    string line;
    while (getline(fin, line)) {
        cout << line << endl;
    }
    fin.close();

    // DELETE MEMORY
